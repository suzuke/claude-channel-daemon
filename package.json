{
  "name": "@suzuke/agend",
  "version": "1.20.1",
  "description": "Multi-agent fleet daemon — run any coding CLI (Claude, Gemini, Codex, OpenCode) from Telegram",
  "type": "module",
  "bin": {
    "agend": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/cli.js",
    "./channel": "./dist/channel/types.js",
    "./channel/access-manager": "./dist/channel/access-manager.js",
    "./channel/message-queue": "./dist/channel/message-queue.js",
    "./types": "./dist/types.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/plugin dist/ && cp -r src/workflow-templates dist/ && cp -r src/ui dist/ && cd dist/plugin/agend && ln -sf ../../channel/mcp-server.js server.js",
    "start": "tsx src/cli.ts start",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suzuke/agend.git"
  },
  "keywords": [
    "agend",
    "agent",
    "fleet",
    "telegram",
    "claude",
    "gemini",
    "codex",
    "opencode",
    "multi-agent",
    "daemon"
  ],
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "README.zh-TW.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "ejs": "^5.0.1",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
