{
  "name": "claude-channel-daemon",
  "version": "0.3.6",
  "description": "Reliable daemon wrapper for Claude Code Channels",
  "type": "module",
  "bin": {
    "ccd": "./dist/cli.js",
    "claude-channel-daemon": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/plugin dist/ && cd dist/plugin/ccd-channel && ln -sf ../../channel/mcp-server.js server.js",
    "start": "tsx src/cli.ts start",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/suzuke/claude-channel-daemon.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "daemon",
    "ai-agent",
    "fleet-management"
  ],
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "README.zh-TW.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "discord.js": "^14.25.1",
    "ejs": "^5.0.1",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
