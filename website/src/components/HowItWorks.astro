---
import type { Locale } from '../i18n/utils';
import en from '../i18n/en.json';
import zhTw from '../i18n/zh-tw.json';

interface Props { locale: Locale }
const { locale } = Astro.props;
const data = locale === 'en' ? en : zhTw;
const steps = data.howitworks.steps;

const iconMap: Record<string, string> = {
  send: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>',
  bot: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/></svg>',
  cpu: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>',
  'git-merge': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>',
  'check-circle': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
};
---

<section id="howitworks" class="py-28 relative">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <p class="section-label mb-3">{data.howitworks.sectionLabel}</p>
      <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight">{data.howitworks.title}</h2>
    </div>

    <!-- Desktop: horizontal flow -->
    <div class="hidden lg:flex items-start justify-between gap-2 stagger">
      {steps.map((step: any, i: number) => (
        <>
          <div class="reveal flex flex-col items-center text-center flex-1">
            <div class="w-16 h-16 rounded-2xl bg-surface border border-border flex items-center justify-center mb-4 text-accent relative">
              <Fragment set:html={iconMap[step.icon]} />
              <div class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-accent animate-pulse-dot" style={`animation-delay: ${i * 400}ms`}></div>
            </div>
            <h3 class="font-display font-bold text-sm mb-1">{step.label}</h3>
            <p class="text-xs text-text-secondary leading-relaxed max-w-[140px]">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="flex items-center pt-8 text-text-muted">
              <svg width="40" height="16" viewBox="0 0 40 16">
                <line x1="0" y1="8" x2="32" y2="8" stroke="currentColor" stroke-width="2" class="animate-flow" style={`animation-delay: ${i * 300}ms`} />
                <polygon points="32,3 40,8 32,13" fill="currentColor" />
              </svg>
            </div>
          )}
        </>
      ))}
    </div>

    <!-- Mobile: vertical flow -->
    <div class="lg:hidden space-y-6 stagger">
      {steps.map((step: any, i: number) => (
        <>
          <div class="reveal flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-surface border border-border flex items-center justify-center shrink-0 text-accent relative">
              <Fragment set:html={iconMap[step.icon]} />
              <div class="absolute -top-1 -right-1 w-2.5 h-2.5 rounded-full bg-accent animate-pulse-dot" style={`animation-delay: ${i * 400}ms`}></div>
            </div>
            <div>
              <h3 class="font-display font-bold text-sm mb-1">{step.label}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{step.desc}</p>
            </div>
          </div>
          {i < steps.length - 1 && (
            <div class="flex justify-center">
              <svg width="16" height="24" viewBox="0 0 16 24" class="text-text-muted">
                <line x1="8" y1="0" x2="8" y2="16" stroke="currentColor" stroke-width="2" class="animate-flow" />
                <polygon points="3,16 8,24 13,16" fill="currentColor" />
              </svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
