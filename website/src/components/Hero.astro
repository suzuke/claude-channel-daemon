---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-16 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 dot-grid opacity-30"></div>
  <div class="absolute inset-0 hero-glow"></div>
  <div class="noise absolute inset-0"></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
    <!-- Tagline -->
    <h1 class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl leading-tight tracking-tight mb-6">
      <span class="block">{t(locale, 'hero.tagline')}</span>
      <span class="block text-accent">{t(locale, 'hero.taglineAccent')}</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-text-secondary font-light leading-relaxed max-w-2xl mx-auto mb-10">
      {t(locale, 'hero.subtitle')}
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-6">
      <a href="#quickstart"
         class="bg-accent text-bg font-semibold px-8 py-3.5 rounded-xl hover:opacity-90 transition-opacity text-base">
        {t(locale, 'hero.cta')}
      </a>
      <a href="https://github.com/suzuke/AgEnD"
         class="border border-border text-text-primary font-semibold px-8 py-3.5 rounded-xl hover:border-text-secondary transition-colors text-base flex items-center justify-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        {t(locale, 'hero.github')}
      </a>
    </div>

    <!-- Badge -->
    <p class="text-sm text-text-muted">{t(locale, 'hero.badges')}</p>
  </div>

  <!-- Terminal mockup -->
  <div class="relative z-10 mt-12 w-full max-w-2xl mx-auto px-6">
    <div class="bg-surface border border-border rounded-2xl overflow-hidden shadow-2xl">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-3 bg-raised border-b border-border">
        <div class="w-3 h-3 rounded-full bg-error/60"></div>
        <div class="w-3 h-3 rounded-full bg-[#e5c07b]/60"></div>
        <div class="w-3 h-3 rounded-full bg-success/60"></div>
        <span class="ml-2 text-xs text-text-muted font-mono">terminal</span>
      </div>
      <!-- Terminal content -->
      <div class="p-5 font-mono text-sm leading-relaxed">
        <p class="text-success">{t(locale, 'terminal.cmd')}</p>
        <p class="text-text-secondary mt-2">{t(locale, 'terminal.line1')}</p>
        <p class="text-text-secondary">{t(locale, 'terminal.line2')}</p>
        <p class="text-text-secondary">{t(locale, 'terminal.line3')}</p>
        <p class="text-text-secondary">{t(locale, 'terminal.line4')}</p>
        <p class="text-accent mt-3 font-semibold">{t(locale, 'terminal.status')}</p>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <div class="w-5 h-8 border-2 border-text-muted rounded-full flex items-start justify-center p-1">
      <div class="w-1 h-2 bg-text-muted rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
